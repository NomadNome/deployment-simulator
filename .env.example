# Anthropic API Key (direct API — recommended for local dev)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Agent backend (vanilla = direct API, strands = Strands SDK)
# AGENT_BACKEND=vanilla

# Optional: AWS Bedrock alternative (set LLM_PROVIDER=bedrock to use)
# LLM_PROVIDER=bedrock
# AWS_REGION=us-east-1
